{
  "project": {
    "name": "CLO garment dataset",
    "output_dir": "dataset"
  },
  "pipeline": {
    "run_stages": [
      2, 3, 4
    ],
    "blender_executable": "blender",
    "python_executable": "python"
  },
  "inputs": {
    "input_dir": "input",
    "garments_dir": "input/garments",
    "fabrics_dir": "input/fabrics"
  },
  "naming": {
    "fabric_dir": "01_fabric_bending",
    "draped_dir": "01_draped_garments",
    "body_proxy_dir": "02_body_proxy_gt",
    "render_dir": "03_blender_multiview",
    "gs_dir": "04_3dgs",
    "fabric_variant_dir_template": "{fabric_id}/{bend_id}",
    "bend_dir_template": "bend_{index:03d}",
    "fabric_file_template": "fabric.zfab",
    "material_json_template": "material.json",
    "sample_dir_template": "{fabric_id}/{garment_id}",
    "draped_zprj_file": "draped_garment.zprj",
    "sample_summary_file": "summary.json",
    "obj_file": "obj.obj",
    "mtl_file": "obj.mtl"
  },
  "fabric_sampler": {
    "sample_count": 10,
    "sample_mode": "paired",
    "sample_distribution": "ui_bucket_jittered",
    "sample_seed": 0,
    "sample_bins": [
      {
        "min": 0.0,
        "max": 20.0,
        "count": 1
      },
      {
        "min": 20.0,
        "max": 50.0,
        "count": 2
      },
      {
        "min": 50.0,
        "max": 70.0,
        "count": 2
      },
      {
        "min": 70.0,
        "max": 100.0,
        "count": 3
      }
    ],
    "preserve_bending_v2_ratio": false,
    "load_samples_into_clo": false,
    "export_through_clo_after_load": false,
    "warp_fields": [
      "fBuK",
      "fBuK_v2"
    ],
    "weft_fields": [
      "fBvK",
      "fBvK_v2"
    ],
    "patch_bending_bias": true,
    "bias_fields": [
      "fBhK",
      "fBhK_v2",
      "fBLeftShearK",
      "fBLeftShearK_v2",
      "fBRightShearK",
      "fBRightShearK_v2"
    ],
    "patch_buckling_stiffness": false
  },
  "clo_simulation": {
    "sim_steps": 300,
    "max_samples": 0,
    "stop_on_first_failure": true,
    "save_sim_zprj": false,
    "skip_render": true,
    "export_obj": true
  },
  "body_proxy_gt": {
    "enabled": true,
    "output_dir": "02_body_proxy_gt",
    "body_dir_template": "{body_id}",
    "avatar_obj_file": "avatar.obj",
    "avatar_meta_file": "avatar_meta.json",
    "proxy_dir": "proxy",
    "proxy_json_file": "body_proxy_gt.json",
    "proxy_tensor_file": "body_proxy_tensor.npy",
    "proxy_png_dir": "slices_png",
    "export_scale": 0.01,
    "num_slices": 10,
    "top_k": 4,
    "slice_min": 0.08,
    "slice_max": 0.88,
    "png_size": 768,
    "reuse_existing": true,
    "stop_on_first_failure": true,
    "python_executable": "python"
  },
  "blender_render": {
    "render_all_samples": true,
    "sample_index": 0,
    "hdri_path": "",
    "num_views": 48,
    "resolution": 512,
    "camera_radius": 0.0,
    "radius_scale": 3.0,
    "lens_mm": 50.0,
    "sensor_width_mm": 36.0,
    "samples": 128,
    "normal_strength": 1.0,
    "world_strength": 0.2,
    "light_scale": 0.12,
    "exposure": -0.2
  },
  "3dgs_training": {
    "enabled": true,
    "gaussian_splatting_dir": "/home/cgna/km/gaussian-splatting",
    "python_executable": "python",
    "extra_args": [
      "--save_iterations",
      "30000"
    ],
    "skip_existing": true,
    "render_after_train": true,
    "render_extra_args": []
  }
}
